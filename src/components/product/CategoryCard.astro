---
interface Props {
  name: string;
  slug: string;
  image?: string;
  count?: number;
}

const { name, slug, image, count } = Astro.props;
---

<a href={`/categorie-produit/${slug}/`} class="group block">
  <div class="relative aspect-[4/3] rounded-2xl overflow-hidden border border-brand-gray-800 bg-brand-black">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(245,217,63,0.28),_transparent_42%),linear-gradient(135deg,_#1f1c1a_0%,_#0f0d0c_100%)]"></div>
    {image ? (
      <div class="absolute inset-0 z-[1] flex items-center justify-center bg-[linear-gradient(180deg,_rgba(15,13,12,0.18)_0%,_rgba(15,13,12,0.4)_100%)] p-4 sm:p-5">
        <img
          src={image}
          alt={name}
          width="480"
          height="360"
          loading="lazy"
          decoding="async"
          class="max-h-full max-w-full object-contain mix-blend-multiply opacity-95 transition-transform duration-500 group-hover:scale-105"
        />
      </div>
    ) : (
      <div class="relative z-[1] flex h-full w-full items-center justify-center bg-gradient-to-br from-brand-gray-800/50 to-transparent px-6 text-center">
        <span class="font-title text-3xl font-bold uppercase tracking-wide text-white/80">{name}</span>
      </div>
    )}
    <div class="absolute inset-0 z-[2] bg-brand-black/22"></div>
    <div class="absolute inset-0 z-[3] bg-gradient-to-t from-brand-black/88 via-brand-black/30 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 z-[4] p-5">
      <h3 class="text-lg font-bold text-brand-white group-hover:text-brand-green transition-colors">
        {name}
      </h3>
      {count !== undefined && (
        <p class="text-sm text-brand-gray-400 mt-0.5">{count} produit{count !== 1 ? "s" : ""}</p>
      )}
    </div>
  </div>
</a>
