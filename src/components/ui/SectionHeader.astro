---
interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
  dark?: boolean;
}

const { title, subtitle, centered = true, dark = false } = Astro.props;
---

<div class:list={["mb-10", centered && "text-center"]}>
  <h2 class:list={["text-3xl sm:text-4xl font-title font-bold uppercase text-balance", dark ? "text-brand-white" : "text-brand-black"]}>
    {title}
  </h2>
  {subtitle && (
    <p class:list={["mt-3 text-lg max-w-2xl", centered && "mx-auto", dark ? "text-brand-gray-400" : "text-brand-black/60"]}>
      {subtitle}
    </p>
  )}
</div>
