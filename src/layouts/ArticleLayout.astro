---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "@components/ui/Breadcrumbs.astro";
import type { SiteMetadata } from "@lib/seo/metadata";
import type { BreadcrumbItem } from "@lib/seo/schema";
import { staticPageSlugs } from "@lib/seo/focusKeywords";

interface Props {
  metadata: SiteMetadata;
  jsonLd?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const { metadata, jsonLd, breadcrumbs } = Astro.props;
---

<BaseLayout metadata={metadata} jsonLd={jsonLd}>
  <article class="bg-brand-white">
    <div class="container-site py-10 sm:py-12">
    {breadcrumbs && breadcrumbs.length > 0 && (
      <Breadcrumbs items={breadcrumbs} />
    )}
    <div class="prose-article max-w-3xl mx-auto mt-6 overflow-hidden">
      <slot />

      <section class="not-prose mt-12 rounded-[28px] border border-brand-gray-200 bg-gray-50 p-6 lg:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-black/50">Méthode éditoriale</p>
        <h2 class="mt-3 text-2xl font-title font-bold uppercase text-brand-black">Comment nous construisons nos contenus</h2>
        <div class="mt-4 space-y-4 text-sm leading-relaxed text-brand-black/70">
          <p>
            Les articles Kilogrammes sont rédigés pour aider à comprendre un produit, un usage ou un sujet réglementaire, puis revus pour améliorer leur clarté, leur conformité éditoriale et leur cohérence avec notre catalogue. Lorsqu'un sujet implique une vérification qualité ou réglementaire, nous recommandons de consulter aussi nos pages <a href={`/${staticPageSlugs.safety}/`} class="font-medium text-brand-black underline underline-offset-2">Safety</a> et <a href={`/${staticPageSlugs.editorial}/`} class="font-medium text-brand-black underline underline-offset-2">Processus éditorial</a>.
          </p>
          <p>
            Nous évitons les promesses vagues et les formulations excessives. Si une information nécessite une validation supplémentaire, elle doit être vérifiée avant publication ou présentée comme telle.
          </p>
        </div>
        <div class="mt-6 flex flex-wrap gap-3 text-sm">
          <a href={`/${staticPageSlugs.support}/`} class="inline-flex items-center rounded-full border border-brand-gray-300 px-4 py-2 text-brand-black hover:border-brand-black transition-colors">Contacter le support</a>
          <a href="/boutique-cbd/" class="inline-flex items-center rounded-full bg-brand-black px-4 py-2 text-brand-white hover:bg-brand-gray-800 transition-colors">Voir la boutique</a>
        </div>
      </section>

      <section class="not-prose mt-8 rounded-[28px] border border-brand-gray-200 bg-white p-6 lg:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-black/50">À lire ensuite</p>
        <h2 class="mt-3 text-2xl font-title font-bold uppercase text-brand-black">Guides recommandés</h2>
        <div class="mt-6 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
          <a href="/blog/comment-choisir-un-grossiste-cbd/" class="rounded-2xl border border-brand-gray-200 p-5 hover:border-brand-black transition-colors">
            <h3 class="text-lg font-title font-bold uppercase text-brand-black">Choisir un grossiste CBD</h3>
            <p class="mt-2 text-sm leading-relaxed text-brand-black/70">Le cadre de lecture pour comparer qualité, traçabilité, logistique et accompagnement B2B.</p>
          </a>
          <a href="/blog/quest-ce-que-le-trim-cbd/" class="rounded-2xl border border-brand-gray-200 p-5 hover:border-brand-black transition-colors">
            <h3 class="text-lg font-title font-bold uppercase text-brand-black">Comprendre le trim CBD</h3>
            <p class="mt-2 text-sm leading-relaxed text-brand-black/70">Un guide simple pour distinguer le trim CBD de la fleur entière et mieux lire une offre.</p>
          </a>
          <a href="/blog/difference-entre-thc-et-thcp/" class="rounded-2xl border border-brand-gray-200 p-5 hover:border-brand-black transition-colors">
            <h3 class="text-lg font-title font-bold uppercase text-brand-black">Différence THC et THCP</h3>
            <p class="mt-2 text-sm leading-relaxed text-brand-black/70">Une comparaison prudente et structurée pour éviter les raccourcis marketing.</p>
          </a>
          <a href="/blog/amnesia-haze-cbd-effets-aromes-differences/" class="rounded-2xl border border-brand-gray-200 p-5 hover:border-brand-black transition-colors">
            <h3 class="text-lg font-title font-bold uppercase text-brand-black">Amnesia Haze CBD</h3>
            <p class="mt-2 text-sm leading-relaxed text-brand-black/70">Arômes, repères de lecture et critères de comparaison avant achat.</p>
          </a>
          <a href="/blog/cbd-est-il-legal-en-italie/" class="rounded-2xl border border-brand-gray-200 p-5 hover:border-brand-black transition-colors">
            <h3 class="text-lg font-title font-bold uppercase text-brand-black">CBD en Italie</h3>
            <p class="mt-2 text-sm leading-relaxed text-brand-black/70">Une lecture prudente pour comprendre achat, livraison et cadre réglementaire italien.</p>
          </a>
          <a href="/blog/comment-choisir-une-huile-cbd/" class="rounded-2xl border border-brand-gray-200 p-5 hover:border-brand-black transition-colors">
            <h3 class="text-lg font-title font-bold uppercase text-brand-black">Choisir une huile CBD</h3>
            <p class="mt-2 text-sm leading-relaxed text-brand-black/70">Les repères essentiels pour comparer dosage, format, lisibilité et qualité.</p>
          </a>
          <a href="/blog/resine-cbd-vs-fleur-cbd/" class="rounded-2xl border border-brand-gray-200 p-5 hover:border-brand-black transition-colors">
            <h3 class="text-lg font-title font-bold uppercase text-brand-black">Résine CBD vs fleur CBD</h3>
            <p class="mt-2 text-sm leading-relaxed text-brand-black/70">Une comparaison claire entre deux catégories majeures du catalogue.</p>
          </a>
        </div>
      </section>
    </div>
    </div>
  </article>
</BaseLayout>
