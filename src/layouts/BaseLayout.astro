---
import SEOHead from "@components/seo/SEOHead.astro";
import Header from "@components/layout/Header.astro";
import Footer from "@components/layout/Footer.astro";
import CookieConsent from "@components/ui/CookieConsent.astro";
import CurrencySwitcher from "@components/ui/CurrencySwitcher.astro";
import type { SiteMetadata } from "@lib/seo/metadata";
import { buildJsonLd, organizationSchema, websiteSchema } from "@lib/seo/schema";
import { staticPageSlugs } from "@lib/seo/focusKeywords";
import "@styles/global.css";

interface Props {
  metadata: SiteMetadata;
  jsonLd?: string;
  bodyClass?: string;
}

const { metadata, jsonLd, bodyClass } = Astro.props;
const globalJsonLd = buildJsonLd([organizationSchema(), websiteSchema()]);
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#2D2926" />

    <SEOHead metadata={metadata} />

  <script is:inline type="application/ld+json" set:html={globalJsonLd} />

    {jsonLd && <script is:inline type="application/ld+json" set:html={jsonLd} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link rel="preload" href="/fonts/MDIO-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/MDIO-Medium.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap" rel="stylesheet" />
  </head>
  <body class:list={["min-h-dvh flex flex-col", bodyClass]}>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:p-4 focus:bg-brand-green focus:text-brand-black">
      Aller au contenu principal
    </a>

    <Header />

    <div class="border-b border-brand-gray-200 bg-brand-white">
      <div class="max-w-[1440px] mx-auto px-6 lg:px-10 py-3">
        <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs uppercase tracking-[0.18em] text-brand-black/60">
          <a href={`/${staticPageSlugs.safety}/`} class="hover:text-brand-black transition-colors">Tests en laboratoire</a>
          <a href={`/${staticPageSlugs.editorial}/`} class="hover:text-brand-black transition-colors">Processus éditorial</a>
          <a href={`/${staticPageSlugs.support}/`} class="hover:text-brand-black transition-colors">Support & livraison</a>
          <a href={`/${staticPageSlugs.delivery}/`} class="hover:text-brand-black transition-colors">Livraison Europe</a>
        </div>
      </div>
    </div>

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <Footer />
    <CurrencySwitcher />
    <CookieConsent />
  </body>
</html>
