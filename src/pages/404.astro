---
import MarketingLayout from "@layouts/MarketingLayout.astro";
import { buildMetadata } from "@lib/seo/metadata";

const metadata = buildMetadata({
  title: "Page non trouvée",
  description: "La page que vous cherchez n'existe pas ou a été déplacée.",
  path: "/404/",
  noindex: true,
});
---

<MarketingLayout metadata={metadata}>
  <section class="bg-brand-white">
    <div class="container-site py-24 min-h-[60vh] flex flex-col items-center justify-center text-center">
      <p class="text-8xl font-bold text-brand-green mb-4 font-title">404</p>
      <h1 class="text-3xl font-bold text-brand-black mb-4 font-title uppercase">Page non trouvée</h1>
      <p class="text-lg text-brand-black/60 max-w-md mb-8">
        La page que vous recherchez n'existe pas ou a été déplacée.
      </p>
      <a href="/" class="btn-primary">Retour à l'accueil</a>
    </div>
  </section>
</MarketingLayout>
