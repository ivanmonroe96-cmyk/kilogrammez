---
import BaseLayout from "@layouts/BaseLayout.astro";
import { buildMetadata } from "@lib/seo/metadata";
import { staticPageSlugs } from "@lib/seo/focusKeywords";

const metadata = buildMetadata({
  title: "Commander - Finalisez Votre Commande CBD",
  description: "Finalisez votre commande CBD Kilogrammes : choisissez votre livraison, confirmez votre paiement en crypto-monnaie et validez votre panier.",
  path: `/${staticPageSlugs.checkout}/`,
  noindex: true,
});
---

<BaseLayout metadata={metadata}>
  <section class="bg-brand-white min-h-[60vh]">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-10 py-12 lg:py-16">
      <a href={`/${staticPageSlugs.cart}/`} class="inline-flex items-center gap-2 text-sm text-brand-black/60 hover:text-brand-black transition-colors mb-6">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Retour au panier
      </a>

      <h1 class="text-3xl sm:text-4xl font-bold text-brand-black mb-10 font-title uppercase">Commander</h1>

      <!-- Empty state -->
      <div id="checkout-empty">
        <p class="text-brand-black/60 text-lg">Votre panier est vide. Ajoutez des produits avant de commander.</p>
        <a href="/boutique-cbd/" class="inline-flex items-center gap-2 bg-brand-yellow text-brand-black font-bold uppercase tracking-wider text-sm py-3 px-8 rounded-lg hover:brightness-95 transition-all mt-6">
          Parcourir la boutique
        </a>
      </div>

      <!-- Checkout content -->
      <div id="checkout-content" class="hidden">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">

          <!-- LEFT: Forms -->
          <div class="lg:col-span-2 space-y-8">

            <!-- Step indicator -->
            <div class="flex flex-wrap items-center gap-2 text-sm font-medium text-brand-black/50">
              <span class="flex items-center gap-1.5"><span class="w-6 h-6 rounded-full bg-brand-black text-white text-xs flex items-center justify-center font-bold">1</span> Livraison</span>
              <span class="w-8 h-px bg-brand-gray-200"></span>
              <span class="flex items-center gap-1.5" id="step-2-label"><span class="w-6 h-6 rounded-full bg-brand-gray-200 text-brand-black/40 text-xs flex items-center justify-center font-bold">2</span> Paiement</span>
              <span class="w-8 h-px bg-brand-gray-200"></span>
              <span class="flex items-center gap-1.5" id="step-3-label"><span class="w-6 h-6 rounded-full bg-brand-gray-200 text-brand-black/40 text-xs flex items-center justify-center font-bold">3</span> Confirmation</span>
            </div>

            <!-- STEP 1: Delivery info -->
            <div id="step-delivery" class="space-y-6">
              <div class="rounded-2xl border border-brand-gray-200 bg-white p-6">
                <h2 class="text-xl font-title font-bold uppercase text-brand-black mb-5">Informations de livraison</h2>
                <form id="delivery-form" class="space-y-4" novalidate>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                      <label for="first-name" class="block text-sm font-medium text-brand-black mb-1">Prénom *</label>
                      <input type="text" id="first-name" name="firstName" required autocomplete="given-name" class="w-full rounded-lg border border-brand-gray-200 px-4 py-2.5 text-sm text-brand-black focus:border-brand-black focus:ring-1 focus:ring-brand-black outline-none transition" />
                    </div>
                    <div>
                      <label for="last-name" class="block text-sm font-medium text-brand-black mb-1">Nom *</label>
                      <input type="text" id="last-name" name="lastName" required autocomplete="family-name" class="w-full rounded-lg border border-brand-gray-200 px-4 py-2.5 text-sm text-brand-black focus:border-brand-black focus:ring-1 focus:ring-brand-black outline-none transition" />
                    </div>
                  </div>
                  <div>
                    <label for="email" class="block text-sm font-medium text-brand-black mb-1">Email *</label>
                    <input type="email" id="email" name="email" required autocomplete="email" class="w-full rounded-lg border border-brand-gray-200 px-4 py-2.5 text-sm text-brand-black focus:border-brand-black focus:ring-1 focus:ring-brand-black outline-none transition" />
                  </div>
                  <div>
                    <label for="phone" class="block text-sm font-medium text-brand-black mb-1">Téléphone</label>
                    <input type="tel" id="phone" name="phone" autocomplete="tel" class="w-full rounded-lg border border-brand-gray-200 px-4 py-2.5 text-sm text-brand-black focus:border-brand-black focus:ring-1 focus:ring-brand-black outline-none transition" />
                  </div>
                  <div>
                    <label for="address" class="block text-sm font-medium text-brand-black mb-1">Adresse *</label>
                    <input type="text" id="address" name="address" required autocomplete="street-address" class="w-full rounded-lg border border-brand-gray-200 px-4 py-2.5 text-sm text-brand-black focus:border-brand-black focus:ring-1 focus:ring-brand-black outline-none transition" />
                  </div>
                  <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
                    <div>
                      <label for="postal-code" class="block text-sm font-medium text-brand-black mb-1">Code postal *</label>
                      <input type="text" id="postal-code" name="postalCode" required autocomplete="postal-code" class="w-full rounded-lg border border-brand-gray-200 px-4 py-2.5 text-sm text-brand-black focus:border-brand-black focus:ring-1 focus:ring-brand-black outline-none transition" />
                    </div>
                    <div>
                      <label for="city" class="block text-sm font-medium text-brand-black mb-1">Ville *</label>
                      <input type="text" id="city" name="city" required autocomplete="address-level2" class="w-full rounded-lg border border-brand-gray-200 px-4 py-2.5 text-sm text-brand-black focus:border-brand-black focus:ring-1 focus:ring-brand-black outline-none transition" />
                    </div>
                    <div class="col-span-2 sm:col-span-1">
                      <label for="country" class="block text-sm font-medium text-brand-black mb-1">Pays *</label>
                      <select id="country" name="country" required class="w-full rounded-lg border border-brand-gray-200 px-4 py-2.5 text-sm text-brand-black focus:border-brand-black focus:ring-1 focus:ring-brand-black outline-none transition bg-white">
                        <option value="FR">France</option>
                        <option value="BE">Belgique</option>
                        <option value="CH">Suisse</option>
                        <option value="LU">Luxembourg</option>
                        <option value="MC">Monaco</option>
                        <option value="IT">Italie</option>
                      </select>
                    </div>
                  </div>
                </form>
              </div>

              <!-- Delivery options -->
              <div class="rounded-2xl border border-brand-gray-200 bg-white p-6">
                <h2 class="text-xl font-title font-bold uppercase text-brand-black mb-5">Mode de livraison</h2>
                <div class="space-y-3" id="delivery-options">
                  <label class="flex flex-col items-start gap-3 p-4 rounded-xl border-2 border-brand-black bg-gray-50 cursor-pointer transition-colors sm:flex-row sm:items-center sm:gap-4 delivery-option">
                    <input type="radio" name="delivery" value="standard" checked class="w-4 h-4 accent-brand-black" />
                    <div class="flex-1">
                      <p class="font-semibold text-brand-black">Livraison Standard</p>
                      <p class="text-sm text-brand-black/60">48-72h ouvrées — Colissimo suivi</p>
                    </div>
                    <span class="font-bold text-brand-black" id="shipping-standard">4,90 €</span>
                  </label>
                  <label class="flex flex-col items-start gap-3 p-4 rounded-xl border-2 border-brand-gray-200 bg-white cursor-pointer transition-colors sm:flex-row sm:items-center sm:gap-4 delivery-option">
                    <input type="radio" name="delivery" value="express" class="w-4 h-4 accent-brand-black" />
                    <div class="flex-1">
                      <p class="font-semibold text-brand-black">Livraison Express</p>
                      <p class="text-sm text-brand-black/60">24h ouvrées — Chronopost</p>
                    </div>
                    <span class="font-bold text-brand-black">9,90 €</span>
                  </label>
                  <label class="flex flex-col items-start gap-3 p-4 rounded-xl border-2 border-brand-gray-200 bg-white cursor-pointer transition-colors sm:flex-row sm:items-center sm:gap-4 delivery-option">
                    <input type="radio" name="delivery" value="relay" class="w-4 h-4 accent-brand-black" />
                    <div class="flex-1">
                      <p class="font-semibold text-brand-black">Point Relais</p>
                      <p class="text-sm text-brand-black/60">3-5 jours ouvrés — Mondial Relay</p>
                    </div>
                    <span class="font-bold text-brand-black">3,90 €</span>
                  </label>
                </div>
                <p class="text-sm text-brand-green font-medium mt-4" id="free-shipping-note" style="display:none;">
                  ✓ Livraison offerte à partir de 100€ d'achat !
                </p>
              </div>

              <button type="button" id="btn-to-payment" class="w-full bg-brand-black text-white font-bold uppercase tracking-wider text-sm py-4 px-8 rounded-xl hover:bg-brand-gray-900 transition-colors">
                Continuer vers le paiement
              </button>
            </div>

            <!-- STEP 2: Payment -->
            <div id="step-payment" class="hidden space-y-6">
              <div class="rounded-2xl border border-brand-gray-200 bg-white p-6">
                <h2 class="text-xl font-title font-bold uppercase text-brand-black mb-5">Mode de paiement</h2>
                <div class="mb-4 rounded-2xl border border-brand-yellow bg-brand-yellow/20 p-4 text-sm leading-relaxed text-brand-black">
                  <p class="font-semibold uppercase tracking-[0.14em]">Paiement crypto uniquement</p>
                  <p class="mt-1 text-brand-black/70">Les commandes sont confirmées uniquement apres reception du paiement en crypto-monnaie. Aucune carte bancaire, aucun compte PayPal et aucun virement bancaire ne sont acceptes.</p>
                </div>
                <div class="space-y-3" id="payment-options">
                  <label class="flex flex-col items-start gap-3 p-4 rounded-xl border-2 border-brand-black bg-gray-50 cursor-pointer transition-colors sm:flex-row sm:items-center sm:gap-4 payment-option">
                    <input type="radio" name="payment" value="crypto" checked class="w-4 h-4 accent-brand-black" />
                    <div class="flex-1">
                      <p class="font-semibold text-brand-black">Crypto-monnaie</p>
                      <p class="text-sm text-brand-black/60">Bitcoin, Ethereum, USDT et autres reseaux pris en charge a la confirmation</p>
                    </div>
                    <div class="flex gap-1.5">
                      <span class="rounded bg-brand-black px-2 py-1 text-[10px] font-bold uppercase tracking-wide text-white">BTC</span>
                      <span class="rounded bg-brand-black px-2 py-1 text-[10px] font-bold uppercase tracking-wide text-white">ETH</span>
                      <span class="rounded bg-brand-black px-2 py-1 text-[10px] font-bold uppercase tracking-wide text-white">USDT</span>
                    </div>
                  </label>
                </div>
              </div>

              <div class="flex flex-col gap-3 sm:flex-row">
                <button type="button" id="btn-back-delivery" class="border border-brand-black text-brand-black font-bold uppercase tracking-wider text-sm py-4 px-8 rounded-xl hover:bg-brand-black hover:text-white transition-colors">
                  Retour
                </button>
                <button type="button" id="btn-confirm-order" class="flex-1 bg-brand-yellow text-brand-black font-bold uppercase tracking-wider text-sm py-4 px-8 rounded-xl hover:brightness-95 transition-all">
                  Confirmer la commande
                </button>
              </div>
            </div>

            <!-- STEP 3: Confirmation -->
            <div id="step-confirmation" class="hidden">
              <div class="rounded-2xl border border-brand-green/30 bg-brand-green/5 p-8 text-center">
                <div class="mx-auto mb-4 w-16 h-16 rounded-full bg-brand-green/20 flex items-center justify-center">
                  <svg class="w-8 h-8 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </div>
                <h2 class="text-2xl font-title font-bold uppercase text-brand-black">Commande confirmée !</h2>
                <p class="text-brand-black/60 mt-2">Merci pour votre commande. Un email de confirmation a été envoyé.</p>
                <p class="text-sm text-brand-black/40 mt-1">Numéro de commande : <span class="font-mono font-bold text-brand-black" id="order-number">—</span></p>
                <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center">
                  <a href="/boutique-cbd/" class="inline-flex items-center justify-center rounded-xl bg-brand-black px-6 py-3 text-sm font-bold uppercase tracking-wider text-white hover:bg-brand-gray-900 transition-colors">
                    Continuer vos achats
                  </a>
                  <a href="/" class="inline-flex items-center justify-center rounded-xl border border-brand-black px-6 py-3 text-sm font-bold uppercase tracking-wider text-brand-black hover:bg-brand-black hover:text-white transition-colors">
                    Retour à l'accueil
                  </a>
                </div>
              </div>
            </div>

          </div>

          <!-- RIGHT: Order summary -->
          <div class="lg:col-span-1" id="order-summary-wrapper">
            <div class="rounded-2xl border border-brand-gray-200 bg-gray-50 p-6 lg:sticky lg:top-[calc(var(--header-offset,0px)+1.5rem)]">
              <h2 class="text-lg font-title font-bold uppercase text-brand-black mb-4">Récapitulatif</h2>
              <div class="space-y-3" id="summary-items"></div>
              <div class="mt-4 pt-4 border-t border-brand-gray-200 space-y-2">
                <div class="flex justify-between text-sm text-brand-black/70">
                  <span>Sous-total</span>
                  <span id="summary-subtotal">0,00 €</span>
                </div>
                <div class="flex justify-between text-sm text-brand-black/70">
                  <span>Livraison</span>
                  <span id="summary-shipping">4,90 €</span>
                </div>
                <div class="flex justify-between text-base font-bold text-brand-black pt-2 border-t border-brand-gray-200">
                  <span>Total</span>
                  <span id="summary-total">0,00 €</span>
                </div>
              </div>
              <p class="mt-4 text-xs text-brand-black/40 leading-relaxed">En confirmant votre commande, vous acceptez nos <a href="/conditions-generales-de-ventes/" class="underline hover:text-brand-black">CGV</a> et notre <a href="/rgpd/" class="underline hover:text-brand-black">politique de confidentialité</a>.</p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<script>
  import { getCart, clearCart, getCartTotal, updateQuantity, removeFromCart } from "@lib/cart";
  import type { CartItem } from "@lib/cart";
  import { formatPrice } from "@lib/currency";

  const shippingPrices: Record<string, number> = { standard: 4.90, express: 9.90, relay: 3.90 };
  let selectedShipping = "standard";

  function getSubtotal(): number {
    return getCartTotal();
  }

  function isFreeShipping(): boolean {
    return getSubtotal() >= 100;
  }

  function getShippingCost(): number {
    return isFreeShipping() ? 0 : (shippingPrices[selectedShipping] || 4.90);
  }

  function clampQuantity(value: number): number {
    if (!Number.isFinite(value) || value < 1) return 1;
    return Math.min(99, Math.round(value));
  }

  function bindSummaryInteractions(summaryItems: HTMLElement) {
    summaryItems.querySelectorAll<HTMLButtonElement>(".summary-qty-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = parseInt(btn.dataset.productId || "0", 10);
        const variation = btn.dataset.variation || undefined;
        const direction = btn.dataset.action;
        const currentItem = getCart().find((item) => item.productId === id && (item.variation || "") === (variation || ""));
        if (!currentItem) return;

        const nextQty = direction === "increase"
          ? currentItem.quantity + 1
          : currentItem.quantity - 1;

        updateQuantity(id, variation, clampQuantity(nextQty));
        if (nextQty <= 0) {
          removeFromCart(id, variation);
        }
        renderSummary();
      });
    });

    summaryItems.querySelectorAll<HTMLButtonElement>(".summary-remove-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = parseInt(btn.dataset.productId || "0", 10);
        const variation = btn.dataset.variation || undefined;
        removeFromCart(id, variation);
        renderSummary();
      });
    });
  }

  function renderSummary() {
    const cart = getCart();
    const summaryItems = document.getElementById("summary-items");
    const subtotalEl = document.getElementById("summary-subtotal");
    const shippingEl = document.getElementById("summary-shipping");
    const totalEl = document.getElementById("summary-total");
    const freeNote = document.getElementById("free-shipping-note");
    const stdLabel = document.getElementById("shipping-standard");

    if (summaryItems) {
      summaryItems.innerHTML = cart.map((item: CartItem) => `
        <div class="rounded-2xl border border-brand-gray-200 bg-white p-3 sm:p-4">
          <div class="flex items-start gap-3">
          <div class="w-12 h-12 rounded-lg overflow-hidden bg-white border border-gray-100 shrink-0">
            ${item.image
              ? `<img src="${item.image}" alt="${item.name}" class="w-full h-full object-cover" loading="lazy" />`
              : `<div class="w-full h-full flex items-center justify-center text-gray-300 text-sm">📦</div>`
            }
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-brand-black truncate">${item.name}</p>
            ${item.variation ? `<p class="text-xs text-brand-black/50">${item.variation}</p>` : ""}
            <p class="text-xs text-brand-black/50 mt-1">Prix unitaire : ${formatPrice(parseFloat(item.price))}</p>
            <div class="mt-3 flex flex-wrap items-center gap-2">
              <div class="inline-flex items-center gap-1 rounded-full border border-brand-gray-200 bg-gray-50 p-1">
                <button type="button" class="summary-qty-btn flex h-8 w-8 items-center justify-center rounded-full text-brand-black transition-colors hover:bg-brand-black hover:text-white" data-action="decrease" data-product-id="${item.productId}" data-variation="${item.variation || ""}" aria-label="Diminuer la quantite de ${item.name}">−</button>
                <span class="w-8 text-center text-sm font-semibold text-brand-black">${item.quantity}</span>
                <button type="button" class="summary-qty-btn flex h-8 w-8 items-center justify-center rounded-full text-brand-black transition-colors hover:bg-brand-black hover:text-white" data-action="increase" data-product-id="${item.productId}" data-variation="${item.variation || ""}" aria-label="Augmenter la quantite de ${item.name}">+</button>
              </div>
              <button type="button" class="summary-remove-btn text-xs font-medium text-red-500 transition-colors hover:text-red-600" data-product-id="${item.productId}" data-variation="${item.variation || ""}">Supprimer</button>
            </div>
          </div>
          <div class="ml-3 shrink-0 text-right">
            <span class="text-sm font-semibold text-brand-black">${formatPrice(parseFloat(item.price) * item.quantity)}</span>
          </div>
        </div>
      `).join("");

      bindSummaryInteractions(summaryItems);
    }

    const subtotal = getSubtotal();
    const shipping = getShippingCost();
    const total = subtotal + shipping;

    if (subtotalEl) subtotalEl.textContent = formatPrice(subtotal);
    if (shippingEl) shippingEl.textContent = isFreeShipping() ? "Offerte" : formatPrice(shipping);
    if (totalEl) totalEl.textContent = formatPrice(total);
    if (freeNote) freeNote.style.display = isFreeShipping() ? "block" : "none";
    if (stdLabel) stdLabel.textContent = isFreeShipping() ? "Offerte" : formatPrice(shippingPrices.standard);
  }

  function setupDeliveryOptions() {
    const options = document.querySelectorAll<HTMLLabelElement>(".delivery-option");
    options.forEach((label) => {
      const radio = label.querySelector<HTMLInputElement>("input[type=radio]");
      if (!radio) return;
      radio.addEventListener("change", () => {
        options.forEach((l) => {
          l.classList.remove("border-brand-black", "bg-gray-50");
          l.classList.add("border-brand-gray-200", "bg-white");
        });
        label.classList.remove("border-brand-gray-200", "bg-white");
        label.classList.add("border-brand-black", "bg-gray-50");
        selectedShipping = radio.value;
        renderSummary();
      });
    });
  }

  function setupPaymentOptions() {
    const options = document.querySelectorAll<HTMLLabelElement>(".payment-option");
    options.forEach((label) => {
      const radio = label.querySelector<HTMLInputElement>("input[type=radio]");
      if (!radio) return;
      radio.addEventListener("change", () => {
        options.forEach((l) => {
          l.classList.remove("border-brand-black", "bg-gray-50");
          l.classList.add("border-brand-gray-200", "bg-white");
        });
        label.classList.remove("border-brand-gray-200", "bg-white");
        label.classList.add("border-brand-black", "bg-gray-50");
      });
    });
  }

  function validateDeliveryForm(): boolean {
    const form = document.getElementById("delivery-form") as HTMLFormElement | null;
    if (!form) return false;
    const requiredFields = form.querySelectorAll<HTMLInputElement | HTMLSelectElement>("[required]");
    let valid = true;
    requiredFields.forEach((field) => {
      if (!field.value.trim()) {
        field.classList.add("border-red-400");
        valid = false;
      } else {
        field.classList.remove("border-red-400");
      }
    });
    // Basic email validation
    const emailField = form.querySelector<HTMLInputElement>("#email");
    if (emailField && emailField.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailField.value)) {
      emailField.classList.add("border-red-400");
      valid = false;
    }
    return valid;
  }

  function validatePaymentForm(): boolean {
    return Boolean(document.querySelector<HTMLInputElement>('input[name="payment"]:checked'));
  }

  function goToStep(step: number) {
    const stepDelivery = document.getElementById("step-delivery");
    const stepPayment = document.getElementById("step-payment");
    const stepConfirmation = document.getElementById("step-confirmation");
    const summaryWrapper = document.getElementById("order-summary-wrapper");
    const step2Label = document.getElementById("step-2-label");
    const step3Label = document.getElementById("step-3-label");

    if (stepDelivery) stepDelivery.classList.toggle("hidden", step !== 1);
    if (stepPayment) stepPayment.classList.toggle("hidden", step !== 2);
    if (stepConfirmation) stepConfirmation.classList.toggle("hidden", step !== 3);
    if (summaryWrapper) summaryWrapper.classList.toggle("hidden", step === 3);

    // Update step indicators
    if (step >= 2 && step2Label) {
      step2Label.innerHTML = `<span class="w-6 h-6 rounded-full bg-brand-black text-white text-xs flex items-center justify-center font-bold">2</span> Paiement`;
    } else if (step2Label) {
      step2Label.innerHTML = `<span class="w-6 h-6 rounded-full bg-brand-gray-200 text-brand-black/40 text-xs flex items-center justify-center font-bold">2</span> Paiement`;
    }
    if (step >= 3 && step3Label) {
      step3Label.innerHTML = `<span class="w-6 h-6 rounded-full bg-brand-green text-brand-black text-xs flex items-center justify-center font-bold">3</span> Confirmation`;
    } else if (step3Label) {
      step3Label.innerHTML = `<span class="w-6 h-6 rounded-full bg-brand-gray-200 text-brand-black/40 text-xs flex items-center justify-center font-bold">3</span> Confirmation`;
    }

    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  function initCheckout() {
    const cart = getCart();
    const emptyEl = document.getElementById("checkout-empty");
    const contentEl = document.getElementById("checkout-content");

    if (!emptyEl || !contentEl) return;

    if (cart.length === 0) {
      emptyEl.classList.remove("hidden");
      contentEl.classList.add("hidden");
      return;
    }

    if (contentEl.dataset.checkoutInit === "1") {
      renderSummary();
      return;
    }

    contentEl.dataset.checkoutInit = "1";

    emptyEl.classList.add("hidden");
    contentEl.classList.remove("hidden");

    renderSummary();
    setupDeliveryOptions();
    setupPaymentOptions();

    // Step navigation
    const btnToPayment = document.getElementById("btn-to-payment");
    const btnBackDelivery = document.getElementById("btn-back-delivery");
    const btnConfirm = document.getElementById("btn-confirm-order");

    btnToPayment?.addEventListener("click", () => {
      if (validateDeliveryForm()) {
        goToStep(2);
      }
    });

    btnBackDelivery?.addEventListener("click", () => {
      goToStep(1);
    });

    btnConfirm?.addEventListener("click", () => {
      if (!validateDeliveryForm() || !validatePaymentForm()) {
        return;
      }

      // Generate pseudo order number
      const orderNum = `KG-${Date.now().toString(36).toUpperCase()}`;
      const orderNumEl = document.getElementById("order-number");
      if (orderNumEl) orderNumEl.textContent = orderNum;

      clearCart();
      goToStep(3);
    });

    window.addEventListener("kg:cart-updated", renderSummary);
    window.addEventListener("kg:currency-changed", renderSummary);
  }

  initCheckout();
  document.addEventListener("astro:page-load", initCheckout);
</script>
