---
import MarketingLayout from "@layouts/MarketingLayout.astro";
import { buildMetadata } from "@lib/seo/metadata";
import { buildJsonLd, breadcrumbSchema, faqSchema } from "@lib/seo/schema";
import { staticPageSlugs } from "@lib/seo/focusKeywords";

export const prerender = true;

const metadata = buildMetadata({
  title: "Grossiste CBD France : Fleurs & Hash B2B",
  description:
    "Grossiste CBD français depuis 2016. Fleurs, résines, huiles en gros à prix dégressifs. Qualité certifiée en labo, livraison Europe.",
  path: `/${staticPageSlugs.wholesale}/`,
});

const grossisteFaq = [
  { question: "Quel est le minimum de commande pour acheter du CBD en gros ?", answer: "Le minimum de commande est de 500g par référence. Ce seuil nous permet de proposer des tarifs professionnels compétitifs tout en garantissant une qualité constante." },
  { question: "Livrez-vous en dehors de la France ?", answer: "Oui, Kilogrammes livre dans toute l'Union européenne ainsi qu'en Outre-mer. Nous traitons régulièrement des commandes vers la Belgique, la Suisse, les Pays-Bas, l'Italie, l'Espagne et le Portugal." },
  { question: "Vos produits CBD en gros sont-ils testés en laboratoire ?", answer: "Chaque lot est systématiquement analysé par un laboratoire indépendant européen. Nous garantissons un taux de THC inférieur à 0,3% et l'absence de pesticides, métaux lourds et solvants." },
  { question: "Peut-on recevoir des échantillons avant de commander ?", answer: "Oui, sur demande nous pouvons envoyer des échantillons de certaines références avant validation d'une commande importante, afin de tester la qualité de nos produits." },
  { question: "Quels sont les délais de livraison pour les commandes en gros ?", answer: "L'expédition est effectuée sous 24 à 48 heures après validation. La livraison prend en moyenne 2 à 5 jours ouvrés selon le pays de destination." },
];

const jsonLd = buildJsonLd([
  breadcrumbSchema([{ name: "Grossiste CBD", url: `/${staticPageSlugs.wholesale}/` }]),
  faqSchema(grossisteFaq),
]);
---

<MarketingLayout metadata={metadata} jsonLd={jsonLd}>
  <section class="bg-brand-black py-24">
    <div class="container-site text-center">
      <p class="text-brand-green text-sm font-medium uppercase tracking-widest mb-4">B2B</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-brand-white leading-tight mb-6 font-title uppercase">
        Grossiste CBD France
      </h1>
      <p class="text-lg text-brand-gray-400 max-w-2xl mx-auto mb-8">
        Producteur et distributeur depuis 2016. Fleurs, résines, huiles et edibles CBD en quantités professionnelles. Prix dégressifs, qualité certifiée, livraison rapide dans toute l'Europe.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://b2b.kilogrammes.com/" target="_blank" rel="noopener noreferrer" class="btn-primary">
          Accéder au catalogue B2B
        </a>
        <a href="/contact/" class="btn-secondary">Demander un devis</a>
      </div>
    </div>
  </section>

  <section class="bg-brand-white py-20">
    <div class="container-site">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
      <div class="bg-white border border-brand-gray-200 rounded-2xl p-8">
        <div class="text-3xl mb-3">📦</div>
        <h3 class="text-lg font-bold text-brand-black mb-2">Large gamme</h3>
        <p class="text-sm text-brand-black/60">Fleurs, résines, huiles, edibles et plus de 250 références disponibles.</p>
      </div>
      <div class="bg-white border border-brand-gray-200 rounded-2xl p-8">
        <div class="text-3xl mb-3">💰</div>
        <h3 class="text-lg font-bold text-brand-black mb-2">Prix compétitifs</h3>
        <p class="text-sm text-brand-black/60">Tarifs dégressifs selon les volumes. Direct producteur, sans intermédiaire.</p>
      </div>
      <div class="bg-white border border-brand-gray-200 rounded-2xl p-8">
        <div class="text-3xl mb-3">🌍</div>
        <h3 class="text-lg font-bold text-brand-black mb-2">Livraison Europe</h3>
        <p class="text-sm text-brand-black/60">Expédition rapide partout en Europe. Suivi personnalisé de vos commandes.</p>
      </div>
    </div>
    </div>
  </section>

  <!-- SEO Content -->
  <section class="bg-gray-50 border-y border-brand-gray-200 py-16">
    <div class="container-site max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-black mb-6 font-title uppercase">Votre fournisseur CBD de confiance</h2>
      <div class="text-brand-black/70 space-y-4 text-sm leading-relaxed">
        <p>En tant que <strong>grossiste CBD français</strong>, Kilogrammes accompagne les professionnels du secteur depuis 2016. Nous maîtrisons l'ensemble du processus : culture indoor, outdoor et greenhouse, séchage, trimming et conditionnement. Cette maîtrise de la chaîne nous permet de proposer les <strong>meilleurs tarifs du marché</strong> sans intermédiaire.</p>
        <p>Notre catalogue professionnel comprend des <strong>fleurs CBD</strong>, du Drysift, du Distillate et bientôt des huiles CBD dosées à 10%, 20%, 30% et 40%. Tous nos produits sont issus de <strong>chanvre cultivé en Europe</strong>, certifiés par laboratoire indépendant avec un taux de THC garanti inférieur à 0,3%.</p>
        <p>Que vous soyez revendeur, e-commerçant ou que vous lanciez votre première <a href="/franchise-cbd/" class="text-brand-green hover:underline font-medium">franchise CBD</a>, notre équipe vous accompagne : choix des produits, stratégie commerciale, logistique et expédition rapide sous 24 à 48h partout en Europe.</p>
      </div>

      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/blog/comment-choisir-un-grossiste-cbd/" class="rounded-2xl border border-brand-gray-200 bg-white p-5 hover:border-brand-black transition-colors">
          <p class="text-xs uppercase tracking-[0.18em] text-brand-black/50">Guide B2B</p>
          <h3 class="mt-2 text-lg font-title font-bold uppercase text-brand-black">Comment choisir un grossiste CBD fiable</h3>
          <p class="mt-2 text-sm leading-relaxed text-brand-black/70">Le guide pour comparer qualité, conformité, traçabilité et logistique avant d'acheter en gros.</p>
        </a>
        <a href="/qualite-securite-cbd/" class="rounded-2xl border border-brand-gray-200 bg-white p-5 hover:border-brand-black transition-colors">
          <p class="text-xs uppercase tracking-[0.18em] text-brand-black/50">Confiance</p>
          <h3 class="mt-2 text-lg font-title font-bold uppercase text-brand-black">Notre méthode qualité</h3>
          <p class="mt-2 text-sm leading-relaxed text-brand-black/70">Comprendre les contrôles laboratoire, la traçabilité et notre logique de conformité.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-brand-white py-16">
    <div class="container-site max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-brand-black mb-8 font-title uppercase">Questions fréquentes — Grossiste CBD</h2>
      <div class="space-y-4">
        {grossisteFaq.map((item) => (
          <details class="group bg-gray-50 border border-brand-gray-200 rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer p-5 text-brand-black font-medium hover:bg-gray-100 transition-colors list-none [&::-webkit-details-marker]:hidden">
              <span class="pr-4">{item.question}</span>
              <svg class="w-5 h-5 shrink-0 text-brand-black/40 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 text-brand-black/60 text-sm leading-relaxed">
              {item.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</MarketingLayout>
