---
import MarketingLayout from "@layouts/MarketingLayout.astro";
import ProductCard from "@components/product/ProductCard.astro";
import BlogCard from "@components/blog/BlogCard.astro";
import { buildMetadata } from "@lib/seo/metadata";
import { buildJsonLd, organizationSchema, websiteSchema, faqSchema } from "@lib/seo/schema";
import { getProducts, getProductCategories, getProductsByCategory } from "@lib/api/woocommerce";
import { getPosts, getFeaturedImage, stripHtml } from "@lib/api/wordpress";
import { getBlogRouteSlug, getCategoryUrl, getDeliveryUrl, getProductRouteSlug, homepagePrimaryKeyword } from "@lib/seo/focusKeywords";

const metadata = buildMetadata({
  title: "Kilogramme Shop : CBD, Hash, Huiles & Edibles",
  description: "Kilogramme shop Kilogrammes : fleurs CBD, hash, simili-THC, huiles et edibles. +250 produits testés en labo, livraison 48h en Europe.",
  path: "/",
});

const homeFaq = [
  { question: "Qu'est-ce que le CBD ?", answer: "Le CBD (cannabidiol) est un cannabinoïde naturel extrait du chanvre. Contrairement au THC, il ne produit pas d'effets psychoactifs. Il est reconnu pour ses propriétés relaxantes et apaisantes et est légal en France et en Europe." },
  { question: "Le CBD est-il légal en France ?", answer: "Oui, le CBD est légal en France et dans l'Union européenne à condition que le taux de THC soit inférieur à 0,3%. Tous les produits Kilogrammes respectent cette réglementation et sont testés en laboratoire." },
  { question: "Quels sont les modes de livraison disponibles ?", answer: "Kilogrammes livre dans toute l'Europe en 48 à 72h. La livraison est discrète et offerte à partir de 100€ d'achat. Nous expédions en France, Belgique, Suisse, Luxembourg, Monaco et Italie." },
  { question: "Comment choisir ses produits CBD ?", answer: "Le choix dépend de vos préférences : les fleurs CBD conviennent à la vaporisation ou l'infusion, les résines offrent une expérience plus concentrée, les huiles permettent un dosage précis, et les edibles sont idéaux pour une consommation discrète. Notre équipe est disponible pour vous conseiller." },
  { question: "Vos produits sont-ils testés en laboratoire ?", answer: "Oui, chaque lot est analysé par un laboratoire indépendant européen. Nous testons la teneur en cannabinoïdes, l'absence de métaux lourds, pesticides et solvants résiduels. Les certificats d'analyse sont disponibles sur demande." },
  { question: "Qu'est-ce que le simili-THC ?", answer: "Les produits simili-THC (ou équivalents THC) sont des cannabinoïdes légaux comme le THCv, H4CBD ou THCP qui procurent des effets similaires au THC traditionnel, tout en restant dans le cadre de la loi européenne avec un taux de THC inférieur à 0,3%." },
];

const jsonLd = buildJsonLd([organizationSchema(), websiteSchema(), faqSchema(homeFaq)]);

// Fetch data in parallel
const [featuredProducts, categories, latestPosts] = await Promise.all([
  getProducts(1, 12).catch(() => []),
  getProductCategories().catch(() => []),
  getPosts(1, 6).catch(() => []),
]);

const postsWithImages = latestPosts.map((post: any) => {
  const image = getFeaturedImage(post);
  return { ...post, _image: image };
});

const findCategoryId = (slug: string) => categories.find((c: any) => c.slug === slug)?.id;

const similiCategoryId = findCategoryId("equivalent-thc");
const flowerCategoryId = findCategoryId("fleurs-cbd");
const hashCategoryId = findCategoryId("resine-cbd-hash-cbg-pollen");
const extractCategoryId = findCategoryId("extracts-cbd");
const accessoriesCategoryId = findCategoryId("accessoires-cbd");

const [similiProducts, flowerProducts, hashProducts, extractProducts, accessoriesProducts] = await Promise.all([
  similiCategoryId ? getProductsByCategory(similiCategoryId).catch(() => []) : Promise.resolve([]),
  flowerCategoryId ? getProductsByCategory(flowerCategoryId).catch(() => []) : Promise.resolve([]),
  hashCategoryId ? getProductsByCategory(hashCategoryId).catch(() => []) : Promise.resolve([]),
  extractCategoryId ? getProductsByCategory(extractCategoryId).catch(() => []) : Promise.resolve([]),
  accessoriesCategoryId ? getProductsByCategory(accessoriesCategoryId).catch(() => []) : Promise.resolve([]),
]);

const hashExtractProducts = [...hashProducts, ...extractProducts].filter(
  (product: any, index: number, list: any[]) => list.findIndex((other: any) => other.id === product.id) === index,
);

// Category data for the grid (with local fallback images)
const displayCategories = [
  { name: "FLEURS CBD", slug: "fleurs-cbd", href: getCategoryUrl({ slug: "fleurs-cbd", name: "Fleurs CBD" }), fallbackImage: "/images/categories/fleurs-cbd.jpg" },
  { name: "HASH", slug: "resine-cbd-hash-cbg-pollen", href: getCategoryUrl({ slug: "resine-cbd-hash-cbg-pollen", name: "Hash CBD" }), fallbackImage: "/images/categories/hash.jpg" },
  { name: "SIMILI-THC", slug: "equivalent-thc", href: getCategoryUrl({ slug: "equivalent-thc", name: "Simili-THC" }), fallbackImage: "/images/categories/simili-thc.jpg" },
  { name: "EXTRACTS", slug: "extracts-cbd", href: getCategoryUrl({ slug: "extracts-cbd", name: "Extracts CBD" }), fallbackImage: "/images/categories/extracts.jpg" },
  { name: "TRIM", slug: "trim-cbd", href: getCategoryUrl({ slug: "trim-cbd", name: "Trim CBD" }), fallbackImage: "/images/categories/trim.jpg" },
  { name: "POPCORN", slug: "popcorns-cbd", href: getCategoryUrl({ slug: "popcorns-cbd", name: "Popcorn CBD" }), fallbackImage: "/images/categories/popcorn.jpg" },
  { name: "EDIBLES", slug: "edibles-cbd", href: getCategoryUrl({ slug: "edibles-cbd", name: "Edibles CBD" }), fallbackImage: "/images/categories/edibles.jpg" },
  { name: "COSMÉTIQUES", slug: "cosmetique-cbd", href: getCategoryUrl({ slug: "cosmetique-cbd", name: "Cosmétiques CBD" }), fallbackImage: "/images/categories/cosmetiques.jpg" },
  { name: "ACCESSOIRES", slug: "accessoires-cbd", href: getCategoryUrl({ slug: "accessoires-cbd", name: "Accessoires CBD" }), fallbackImage: "/images/categories/accessoires.jpg" },
  { name: "HUILES CBD", slug: "huiles-cbd", href: getCategoryUrl({ slug: "huiles-cbd", name: "Huiles CBD" }), fallbackImage: "/images/categories/huiles-cbd.jpg" },
  { name: "CHAMPIGNONS", slug: "champignons", href: getCategoryUrl({ slug: "champignons", name: "Champignons" }), fallbackImage: "/images/categories/champignons.jpg" },
  { name: "BONS PLANS", slug: "bons-plans", href: getCategoryUrl({ slug: "bons-plans", name: "Bons Plans" }), fallbackImage: "/images/categories/bons-plans.jpg" },
];

// Enrich categories with images — prefer API image, fall back to local
const enrichedCategories = displayCategories.map((cat) => {
  const apiCat = categories.find((c: any) => c.slug === cat.slug);
  return { ...cat, image: apiCat?.image?.src || cat.fallbackImage, count: apiCat?.count || 0 };
});

const heroDrops = [
  {
    title: "NEW DROP : BUBBLE HASH FROZEN THX !",
    description: "Gras, brillant, presque huileux : notre nouveau Bubble Hash Frozen THX est bien plus costaud qu'il en a l'air ! Attention, à manier avec prudence...",
    href: "/produit/bubble-hash-frozen-thx/",
    cta: "Let's go !",
    image: "/images/hero/bubble-hash-frozen-thx.png",
  },
  {
    title: "NEW DROP : TERIYAKI SAUCE THX !",
    description: "À la croisée des terpènes sucrés-salés et de la détente massive : découvre notre Teriayki Sauce THX, une exclu qui tape juste.",
    href: "/produit/teriyaki-sauce-thx/",
    cta: "Je shoppe !",
    image: "/images/hero/teriyaki-sauce-thx.png",
  },
  {
    title: "ATTENTION : EFFETS GARANTIS !",
    description: "Un seul bonbon, une seule dose, 4 parfums au choix : nos gummies THC Death Kubes font le taf. Pas de surprise, que du résultat.",
    href: "/produit/gummies-thc-15mg/",
    cta: "Je fonce !",
    image: "/images/hero/death-kubes.png",
  },
];

const shopLocations = [
  { name: "Amiens", href: getDeliveryUrl({ name: "Amiens", slug: "amiens", country: "France" }), address: "209 rue Jules Barni, 80090" },
  { name: "Lille", href: getDeliveryUrl({ name: "Lille", slug: "lille", country: "France" }), address: "64 rue de l'Hôpital Militaire, 59000" },
  { name: "Saint-Étienne", href: getDeliveryUrl({ name: "Saint-Étienne", slug: "saint-etienne", country: "France" }), address: "26 rue Gambetta, 42000" },
  { name: "Toulouse", href: getDeliveryUrl({ name: "Toulouse", slug: "toulouse", country: "France" }), address: "14 rue Pharaon, 31000" },
  { name: "Cambrai", href: getDeliveryUrl({ name: "Cambrai", slug: "cambrai", country: "France" }), address: "50 rue des Rôtisseurs, 59400" },
];

---

<MarketingLayout metadata={metadata} jsonLd={jsonLd}>

  <!-- ═══════════════════════════════════════════
       HERO SECTION — Full-width slider
  ═══════════════════════════════════════════ -->
  <section class="relative bg-brand-black overflow-hidden" id="hero-slider">
    <!-- SEO H1 — visually hidden, accessible to search engines -->
    <h1 class="sr-only">{homepagePrimaryKeyword} : fleurs CBD, hash, simili-THC et edibles Kilogrammes</h1>
    <div class="relative">
      {heroDrops.map((drop, index) => (
        <div
          class:list={[
            "hero-slide",
            index === 0 ? "hero-slide--active" : "",
          ]}
          data-slide={index}
        >
          <div class="max-w-[1440px] mx-auto px-6 lg:px-10 py-12 lg:py-20">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-0 items-center min-h-[400px] lg:min-h-[520px]">
              <div class="relative z-10">
                <h2 class="text-[2.5rem] sm:text-[3.5rem] lg:text-[4.5rem] xl:text-[5.5rem] font-bold text-brand-white leading-[0.9] uppercase font-title mb-5 lg:mb-7">
                    {drop.title}
                </h2>
                <p class="text-brand-gray-300 text-sm lg:text-base max-w-lg leading-relaxed font-mono">
                  {drop.description}
                </p>
              </div>
              <div class="relative flex items-center justify-center lg:justify-end">
                <img
                  src={drop.image}
                  alt={drop.title}
                  class="w-[280px] sm:w-[350px] lg:w-[450px] xl:w-[550px] h-auto object-contain drop-shadow-2xl"
                  loading={index === 0 ? "eager" : "lazy"}
                />
              </div>
            </div>
            <!-- CTA button centered -->
            <div class="flex justify-center mt-8 lg:mt-10">
              <a href={drop.href} class="hero-cta group inline-flex items-center gap-3 rounded-full border-2 border-brand-gray-600 px-6 py-3 transition-all duration-300 hover:border-brand-yellow hover:bg-brand-yellow">
                <span class="flex items-center justify-center w-10 h-10 rounded-full bg-brand-yellow text-brand-black transition-colors">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
                </span>
                <span class="text-brand-white font-mono font-bold text-sm tracking-wide group-hover:text-brand-black transition-colors">{drop.cta}</span>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
    <!-- Slider dots -->
    <div class="flex justify-center gap-2 pb-8" id="hero-dots">
      {heroDrops.map((_, index) => (
        <button
          class:list={[
            "hero-dot w-2.5 h-2.5 rounded-full transition-all duration-300",
            index === 0 ? "bg-brand-white scale-110" : "bg-brand-gray-600 hover:bg-brand-gray-400",
          ]}
          data-dot={index}
          aria-label={`Slide ${index + 1}`}
        />
      ))}
    </div>
  </section>

  <style>
    .hero-slide {
      display: none;
      animation: heroFadeIn 0.6s ease-out;
    }
    .hero-slide--active {
      display: block;
    }
    @keyframes heroFadeIn {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>

  <script>
    function initHeroSlider() {
      const slides = document.querySelectorAll<HTMLElement>('.hero-slide');
      const dots = document.querySelectorAll<HTMLElement>('.hero-dot');
      if (slides.length === 0) return;

      let current = 0;
      let timer: ReturnType<typeof setInterval>;

      function goTo(index: number) {
        slides[current].classList.remove('hero-slide--active');
        dots[current].classList.remove('bg-brand-white', 'scale-110');
        dots[current].classList.add('bg-brand-gray-600');

        current = index;

        slides[current].classList.add('hero-slide--active');
        dots[current].classList.remove('bg-brand-gray-600');
        dots[current].classList.add('bg-brand-white', 'scale-110');
      }

      function next() {
        goTo((current + 1) % slides.length);
      }

      function startTimer() {
        timer = setInterval(next, 6000);
      }

      function resetTimer() {
        clearInterval(timer);
        startTimer();
      }

      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          goTo(i);
          resetTimer();
        });
      });

      startTimer();
    }

    document.addEventListener('astro:page-load', initHeroSlider);
    if (document.readyState !== 'loading') {
      initHeroSlider();
    } else {
      document.addEventListener('DOMContentLoaded', initHeroSlider);
    }
  </script>

  <!-- ═══════════════════════════════════════════
       ATTENTION : EFFETS GARANTIS banner
  ═══════════════════════════════════════════ -->
  <section class="bg-brand-black py-3 overflow-hidden border-y border-brand-gray-900">
    <div class="flex whitespace-nowrap animate-marquee">
      {[...Array(8)].map(() => (
        <span class="inline-flex items-center gap-4 mx-6 text-brand-white font-bold uppercase tracking-wider text-sm shrink-0">
          Livraison offerte à partir de 100€ !
          <svg class="w-3 h-3 text-brand-yellow" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </span>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       NOS SIMILI-THC — Product Section
  ═══════════════════════════════════════════ -->
  {(similiProducts.length > 0 || featuredProducts.length > 0) && (
    <section class="bg-brand-black py-16 lg:py-24">
      <div class="max-w-[1440px] mx-auto px-6 lg:px-10">
        <div class="mb-10">
          <h2 class="text-3xl lg:text-5xl font-bold text-brand-white uppercase font-title mb-3">NOS SIMILI-THC</h2>
          <p class="text-brand-gray-400 max-w-2xl">
            La gamme équivalente au THC : retrouvez enfin les effets que vous recherchez, légalement, et livrés chez vous en 48 à 72 h pour un maximum de détente !
          </p>
        </div>

        <!-- Horizontal scrolling product carousel -->
        <div class="overflow-x-auto scrollbar-hide -mx-6 px-6 lg:-mx-10 lg:px-10">
          <div class="flex gap-5" style="width: max-content;">
            {(similiProducts.length > 0 ? similiProducts : featuredProducts).slice(0, 8).map((product: any) => (
              <div class="w-[260px] shrink-0">
                <ProductCard                  id={product.id}                  name={product.name}
                  slug={getProductRouteSlug(product)}
                  price={product.price}
                  regularPrice={product.regular_price}
                  salePrice={product.sale_price}
                  image={product.images?.[0]?.src}
                  stockStatus={product.stock_status}
                  attributes={product.attributes}
                  averageRating={product.average_rating}
                  ratingCount={product.rating_count}
                />
              </div>
            ))}
          </div>
        </div>

        <div class="mt-10">
          <a href="/categorie-produit/equivalent-thc/" class="inline-flex items-center gap-2 border border-brand-white text-brand-white rounded-full px-8 py-3 text-sm uppercase tracking-wider font-bold hover:bg-brand-white hover:text-brand-black transition-colors">
            Nos alternatives au THC
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════
       FLEURS DE CANNABIS
  ═══════════════════════════════════════════ -->
  {(flowerProducts.length > 0 || featuredProducts.length > 0) && (
    <section class="bg-brand-white pt-0 pb-8 lg:pb-14">
      <div class="max-w-[1440px] mx-auto px-6 lg:px-10">
        <div class="mb-10 pt-16 lg:pt-20">
          <h2 class="text-3xl lg:text-5xl font-bold text-brand-black uppercase font-title mb-3">Fleurs de Cannabis</h2>
          <p class="text-brand-black/60 max-w-3xl">
            Des variétés sélectionnées pour leurs qualités terpéniques et un curing bien effectué pour faire ressortir tout leur potentiel : goûtez à du cannabis de qualité, cultivé avec le knowledge nécessaire.
          </p>
        </div>

        <div class="overflow-x-auto scrollbar-hide -mx-6 px-6 lg:-mx-10 lg:px-10">
          <div class="flex gap-5" style="width: max-content;">
            {(flowerProducts.length > 0 ? flowerProducts : featuredProducts).slice(0, 10).map((product: any) => (
              <div class="w-[260px] shrink-0">
                <ProductCard
                  id={product.id}
                  name={product.name}
                  slug={getProductRouteSlug(product)}
                  price={product.price}
                  regularPrice={product.regular_price}
                  salePrice={product.sale_price}
                  image={product.images?.[0]?.src}
                  stockStatus={product.stock_status}
                  attributes={product.attributes}
                  averageRating={product.average_rating}
                  ratingCount={product.rating_count}
                />
              </div>
            ))}
          </div>
        </div>

        <div class="mt-8 flex justify-center md:justify-end">
          <a href="/categorie-produit/fleurs-cbd/" class="inline-flex items-center gap-2 border border-brand-black text-brand-black rounded-full px-8 py-3 text-sm uppercase tracking-wider font-bold hover:bg-brand-black hover:text-brand-white transition-colors">
            Toutes les fleurs CBD
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════
       HASHS & EXTRACTS
  ═══════════════════════════════════════════ -->
  <section class="bg-brand-black py-16 lg:py-20">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-10">
      <h2 class="text-3xl lg:text-5xl font-bold text-brand-white uppercase font-title mb-4">HASHS &amp; EXTRACTS</h2>
      <p class="text-brand-gray-400 max-w-4xl text-base lg:text-lg">
        Fabriqués à partir de fleurs CBD / CBG rigoureusement sélectionnées, nos hashs &amp; extracts CBD / CBG sont travaillés sans aucun solvant mais avec beaucoup d'amour. De quoi oublier tous les mauvais hashs que vous avez croisés jusqu'à maintenant.
      </p>

      {(hashExtractProducts.length > 0 || featuredProducts.length > 0) && (
        <div class="mt-10 overflow-x-auto scrollbar-hide -mx-6 px-6 lg:-mx-10 lg:px-10">
          <div class="flex gap-5" style="width: max-content;">
            {(hashExtractProducts.length > 0 ? hashExtractProducts : featuredProducts).slice(0, 10).map((product: any) => (
              <div class="w-[260px] shrink-0">
                <ProductCard
                  id={product.id}
                  name={product.name}
                  slug={getProductRouteSlug(product)}
                  price={product.price}
                  regularPrice={product.regular_price}
                  salePrice={product.sale_price}
                  image={product.images?.[0]?.src}
                  stockStatus={product.stock_status}
                  attributes={product.attributes}
                  averageRating={product.average_rating}
                  ratingCount={product.rating_count}
                />
              </div>
            ))}
          </div>
        </div>
      )}
      <div class="mt-10">
        <a href="/categorie-produit/resine-cbd-hash-cbg-pollen/" class="inline-flex items-center gap-2 border border-brand-white text-brand-white rounded-full px-8 py-3 text-sm uppercase tracking-wider font-bold hover:bg-brand-white hover:text-brand-black transition-colors">
          Nos Hashs & Extracts CBD
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       BRAND STORY — Terpsquad / About section
  ═══════════════════════════════════════════ -->
  <section class="bg-brand-black border-t border-brand-gray-900">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-10 py-16 lg:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="rounded-2xl overflow-hidden bg-brand-gray-900 aspect-video">
          <img
            src="/images/homepage/terpsquad-bg.jpg"
            alt="Terpsquad by Kilogrammes"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div>
          <img
            src="/images/homepage/terpsquad-logo.png"
            alt="Terpsquad"
            class="h-14 lg:h-20 w-auto mb-6"
            loading="lazy"
          />
          <h2 class="text-3xl lg:text-4xl font-bold text-brand-white uppercase font-title mb-6">
            De cannabis connaisseurs à cannabis entrepreneurs
          </h2>
          <p class="text-brand-gray-400 leading-relaxed mb-4">
            Depuis 2016, Kilogrammes donne tout pour vous proposer la meilleure qualité au prix juste. Comment ?
          </p>
          <p class="text-brand-gray-400 leading-relaxed mb-8">
            Pas d'intermédiaires, on fait tout nous-mêmes, du début à la fin, en suivant un protocole précis qui nous permet d'obtenir les meilleurs produits du marché — et ça, c'est vous qui le dites.
          </p>
          <a href="/categorie-produit/fleurs-cbd/" class="inline-flex items-center gap-2 border border-brand-white text-brand-white rounded-full px-8 py-3 text-sm uppercase tracking-wider font-bold hover:bg-brand-white hover:text-brand-black transition-colors">
            Fleurs CBD
          </a>
          <a href="/categorie-produit/resine-cbd-hash-cbg-pollen/" class="inline-flex items-center gap-2 border border-brand-white text-brand-white rounded-full px-8 py-3 text-sm uppercase tracking-wider font-bold hover:bg-brand-white hover:text-brand-black transition-colors ml-3">
            Hash
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CATEGORIES GRID
  ═══════════════════════════════════════════ -->
  <section class="bg-brand-black py-14 lg:py-22">
    <div class="max-w-[1440px] mx-auto px-4 lg:px-10">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 lg:gap-5">
        {enrichedCategories.map((cat) => (
          <a
            href={cat.href}
            class="group relative rounded-lg overflow-hidden bg-brand-gray-900 aspect-square flex items-center justify-center"
          >
            {cat.image && (
              <img
                src={cat.image}
                alt={cat.name}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            )}
            <div class="absolute inset-0 bg-black/30 group-hover:bg-black/40 transition-colors"></div>
            <span class="relative text-brand-white font-bold uppercase tracking-wider text-base lg:text-[2rem] font-title text-center drop-shadow-[0_2px_4px_rgba(0,0,0,0.5)] px-2">
              {cat.name}
            </span>
          </a>
        ))}
      </div>
