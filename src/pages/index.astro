  <script>
    function initReviewsCarousel() {
      const track = document.getElementById('reviews-track') as HTMLElement | null;
      const prevBtn = document.getElementById('reviews-prev');
      const nextBtn = document.getElementById('reviews-next');
      if (!track) return;

      const cards = track.querySelectorAll('.review-card');
      if (cards.length === 0) return;

      let offset = 0;
      const gap = 20;

      function getCardWidth() {
        return (cards[0] as HTMLElement).offsetWidth + gap;
      }

      function getVisibleCount() {
        return Math.floor(track!.parentElement!.offsetWidth / getCardWidth()) || 1;
      }

      function getMaxOffset() {
        return Math.max(0, cards.length - getVisibleCount());
      }

      function slide() {
        track!.style.transform = `translateX(-${offset * getCardWidth()}px)`;
      }

      function next() {
        offset = offset >= getMaxOffset() ? 0 : offset + 1;
        slide();
      }

      function prev() {
        offset = offset <= 0 ? getMaxOffset() : offset - 1;
        slide();
      }

      if (prevBtn) prevBtn.addEventListener('click', prev);
      if (nextBtn) nextBtn.addEventListener('click', next);

      // Touch / drag support
      let startX = 0;
      let isDragging = false;

      track.addEventListener('touchstart', (e) => {
        startX = e.touches[0].clientX;
        isDragging = true;
      }, { passive: true });

      track.addEventListener('touchend', (e) => {
        if (!isDragging) return;
        isDragging = false;
        const diff = startX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) {
          diff > 0 ? next() : prev();
        }
      });

      // Auto-play
      let autoTimer = setInterval(next, 5000);
      const container = track.parentElement!.parentElement!;
      container.addEventListener('mouseenter', () => clearInterval(autoTimer));
      container.addEventListener('mouseleave', () => { autoTimer = setInterval(next, 5000); });
    }

    document.addEventListener('astro:page-load', initReviewsCarousel);
    if (document.readyState !== 'loading') {
      initReviewsCarousel();
    } else {
      document.addEventListener('DOMContentLoaded', initReviewsCarousel);
    }
  </script>

