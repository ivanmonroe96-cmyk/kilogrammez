---
import MarketingLayout from "@layouts/MarketingLayout.astro";
import { buildMetadata } from "@lib/seo/metadata";
import { buildJsonLd, breadcrumbSchema } from "@lib/seo/schema";
import { deliveryCountries, deliveryLocations } from "@/data/navigation";
import { getBlogUrl, getDeliveryUrl, staticPageSlugs } from "@lib/seo/focusKeywords";

export const prerender = true;

const metadata = buildMetadata({
  title: "Livraison CBD Europe : 6 Pays, 48-72h",
  description: "Livraison CBD rapide et discrète en France, Belgique, Suisse, Luxembourg, Monaco et Italie. Offerte dès 100€. Expédition sous 48h.",
  path: `/${staticPageSlugs.delivery}/`,
});

const jsonLd = buildJsonLd([
  breadcrumbSchema([{ name: "Livraison CBD", url: `/${staticPageSlugs.delivery}/` }]),
]);

// Group locations by country
const locationsByCountry = deliveryCountries.map((country) => ({
  ...country,
  cities: deliveryLocations.filter((loc) => loc.countryCode === country.code),
}));
---

<MarketingLayout metadata={metadata} jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="bg-brand-black py-12 sm:py-16">
    <div class="container-site">
    <h1 class="text-3xl sm:text-5xl font-bold text-brand-white mb-4 text-center font-title uppercase break-words">
      Livraison CBD en Europe
    </h1>
    <p class="text-base sm:text-lg text-brand-gray-400 text-center max-w-2xl mx-auto mb-6 leading-relaxed">
      Nous livrons vos produits CBD premium dans 6 pays européens. Livraison rapide, discrète et offerte dès 100€.
    </p>

    <!-- Country flags row -->
    <div class="flex flex-wrap justify-center gap-4">
      {deliveryCountries.map((country) => (
        <div class="flex items-center gap-2 border border-brand-gray-600 rounded-full px-5 py-2.5">
          <span class="text-xl">{country.flag}</span>
          <span class="text-sm font-medium text-brand-white">{country.name}</span>
        </div>
      ))}
    </div>
    </div>
  </section>

  <!-- Locations -->
  <section class="bg-brand-white py-12 sm:py-16">
    <div class="container-site">
    {locationsByCountry.map((country) => (
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-brand-black mb-6 font-title uppercase flex items-center gap-3">
          <span class="text-3xl">{country.flag}</span>
          {country.name}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
          {country.cities.map((city) => (
            <a
              href={getDeliveryUrl(city)}
              class="group bg-white border border-brand-gray-200 rounded-2xl p-6 hover:border-brand-black/50 transition-colors"
            >
              <h3 class="text-lg font-bold text-brand-black group-hover:text-brand-green transition-colors mb-1">
                {city.name}
              </h3>
              <p class="text-xs text-brand-black/50 mb-3">Livraison CBD à {city.name}</p>
              <span class="inline-flex items-center gap-1 text-sm text-brand-green font-medium">
                Découvrir
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    ))}

    <!-- CTA -->
    <div class="text-center mt-8">
      <a href="/boutique-cbd/" class="btn-primary text-base py-3 px-10">Commander maintenant</a>
    </div>
    </div>
  </section>

  <section class="bg-gray-50 border-t border-gray-100 py-12 lg:py-16">
    <div class="container-site">
      <div class="max-w-3xl">
        <h2 class="text-2xl lg:text-4xl font-title font-bold uppercase text-brand-black break-words">Guides utiles avant de commander</h2>
        <p class="mt-4 text-sm lg:text-base leading-relaxed text-brand-black/70">
          Les pages de livraison répondent à l'intention locale, mais les visiteurs ont aussi besoin de repères sur la réglementation, les catégories et les formats. Voici les guides les plus utiles pour compléter une recherche géographique par une vraie lecture d'achat.
        </p>
      </div>
      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
        <a href={getBlogUrl({ slug: "cbd-est-il-legal-en-italie", title: { rendered: "CBD en Italie : est-ce légal ?" } })} class="rounded-2xl border border-brand-gray-200 bg-white p-5 hover:border-brand-black transition-colors">
          <h3 class="text-lg font-title font-bold uppercase text-brand-black">CBD en Italie</h3>
          <p class="mt-2 text-sm text-brand-black/70">Pour les recherches autour de Rome, Milan ou Bologne, ce guide clarifie le cadre à vérifier avant commande.</p>
        </a>
        <a href={getBlogUrl({ slug: "comment-choisir-une-huile-cbd", title: { rendered: "Comment choisir une huile CBD" } })} class="rounded-2xl border border-brand-gray-200 bg-white p-5 hover:border-brand-black transition-colors">
          <h3 class="text-lg font-title font-bold uppercase text-brand-black">Choisir une huile CBD</h3>
          <p class="mt-2 text-sm text-brand-black/70">Un guide simple pour comparer concentration, format et lisibilité avant achat.</p>
        </a>
        <a href={getBlogUrl({ slug: "resine-cbd-vs-fleur-cbd", title: { rendered: "Résine CBD vs fleur CBD : comment choisir ?" } })} class="rounded-2xl border border-brand-gray-200 bg-white p-5 hover:border-brand-black transition-colors">
          <h3 class="text-lg font-title font-bold uppercase text-brand-black">Résine CBD vs fleur CBD</h3>
          <p class="mt-2 text-sm text-brand-black/70">Pour aider les visiteurs à choisir entre les deux grandes familles les plus consultées.</p>
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>
