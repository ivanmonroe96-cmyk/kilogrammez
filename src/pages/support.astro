---
import MarketingLayout from "@layouts/MarketingLayout.astro";
import { buildMetadata } from "@lib/seo/metadata";
import { buildJsonLd, breadcrumbSchema, faqSchema } from "@lib/seo/schema";
import { staticPageSlugs } from "@lib/seo/focusKeywords";

export const prerender = true;

const metadata = buildMetadata({
  title: "Support",
  description:
    "Besoin d'aide ? Consultez notre page support pour trouver des réponses à vos questions sur les commandes, la livraison et nos produits CBD.",
  path: `/${staticPageSlugs.support}/`,
});

const supportFaq = [
  {
    question: "Quel est le délai de livraison ?",
    answer:
      "Les commandes sont expédiées sous 24 heures ouvrées. La livraison standard prend généralement 2 à 4 jours en France métropolitaine, selon le transporteur et la destination.",
  },
  {
    question: "Comment suivre ma commande ?",
    answer:
      "Un email comportant votre numéro de suivi est envoyé au moment de l'expédition. Vous pouvez également retrouver les informations utiles depuis votre espace client lorsque ce service est disponible.",
  },
  {
    question: "Vos produits sont-ils légaux ?",
    answer:
      "Oui. Les produits commercialisés respectent le cadre réglementaire européen applicable, notamment sur le seuil de THC. Chaque lot est contrôlé afin de vérifier conformité et qualité.",
  },
  {
    question: "Comment retourner un produit ?",
    answer:
      "Les demandes de retour doivent être effectuées dans le délai légal applicable. Les modalités détaillées sont disponibles sur la page Remboursements et retours et peuvent varier selon la nature du produit.",
  },
  {
    question: "Quels moyens de paiement acceptez-vous ?",
    answer:
      "Les commandes sont réglées exclusivement en crypto-monnaie. Les instructions de paiement sont affichées au moment de la confirmation de commande.",
  },
];

const jsonLd = buildJsonLd([
  breadcrumbSchema([{ name: "Support", url: `/${staticPageSlugs.support}/` }]),
  faqSchema(supportFaq),
]);
---

<MarketingLayout metadata={metadata} jsonLd={jsonLd}>
  <section class="bg-brand-white">
    <div class="container-site py-12 sm:py-16 max-w-3xl mx-auto">
    <h1 class="text-3xl sm:text-5xl font-bold text-brand-black mb-4 font-title uppercase break-words">Support</h1>
    <p class="text-base sm:text-lg text-brand-black/60 mb-10 sm:mb-12 leading-relaxed">
      Nous sommes là pour vous aider. Retrouvez les réponses essentielles sur les commandes, la livraison, le paiement en crypto-monnaie et la conformité de nos produits CBD.
    </p>

    <div class="mb-10 rounded-2xl border border-brand-gray-200 bg-gray-50 p-6 text-sm leading-relaxed text-brand-black/70">
      <p>
        Cette page support sert de point d'entrée rapide avant contact. Si votre question concerne le suivi d'une commande, un retour, la livraison ou la légalité d'un produit, commencez ici. Pour les sujets relatifs à la qualité et à la traçabilité, vous pouvez également consulter notre page <a href={`/${staticPageSlugs.safety}/`} class="font-medium text-brand-black underline underline-offset-2">Safety</a>.
      </p>
    </div>

    <div class="space-y-6">
      {supportFaq.map((faq) => (
        <details class="bg-white border border-brand-gray-200 rounded-xl group overflow-hidden">
          <summary class="px-5 sm:px-6 py-4 cursor-pointer text-brand-black font-medium flex items-center justify-between gap-3 text-sm sm:text-base">
            {faq.question}
            <span class="text-brand-gray-400 group-open:rotate-45 transition-transform text-xl">+</span>
          </summary>
          <div class="px-5 sm:px-6 pb-4 text-sm leading-relaxed text-brand-black/70">{faq.answer}</div>
        </details>
      ))}
    </div>

    <div class="mt-12 p-6 sm:p-8 bg-gray-50 border border-brand-gray-200 rounded-2xl text-center">
      <h2 class="text-lg sm:text-xl font-bold text-brand-black mb-2 font-title uppercase break-words">Vous n'avez pas trouvé votre réponse ?</h2>
      <p class="text-sm text-brand-black/60 mb-4">Notre équipe est disponible pour vous aider.</p>
      <a href="/contact/" class="btn-primary">Nous contacter</a>
    </div>
    </div>
  </section>
</MarketingLayout>
